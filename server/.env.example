# Example environment variables for local development
# Copy this file to .env.development or .env.production and fill in real values.

DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?pgbouncer=true"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?pgbouncer=true"
GITHUB_KEY="your_github_token_here" # replace with a real GitHub Personal Access Token
PORT=5000
NODE_MODE=development
