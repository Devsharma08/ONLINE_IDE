generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Answer {
  id         String   @id
  text       String
  questionId String
  createdAt  DateTime @default(now())
  authorId   String
  User       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  Question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model College {
  id                     String                   @id
  name                   String
  location               String
  state                  String?
  city                   String?
  rating                 Float
  fees                   Int
  popularFor             String
  imgUrl                 String
  type                   String?
  CollegeDetails         CollegeDetails?
  CollegeFacility        CollegeFacility[]
  Course                 Course[]
  Cutoff                 Cutoff[]
  Event                  Event[]
  PlacementStat          PlacementStat[]
  Question               Question[]
  Review                 Review[]
  UserCollegePreferences UserCollegePreferences[]

  @@index([city])
  @@index([fees])
  @@index([name])
  @@index([rating])
  @@index([state, fees])
  @@index([state])
  @@index([state, rating])
  @@index([type])
}

model CollegeDetails {
  id          String  @id
  collegeId   String  @unique
  description String
  imageUrl    String
  programs    String
  College     College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model CollegeFacility {
  collegeId  String
  facilityId String
  College    College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  Facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([collegeId, facilityId])
}

model Course {
  id               String          @id
  collegeId        String
  name             String
  level            String
  durationInYears  Int
  tuitionFee       Int
  seatsAvailable   Int?
  courseCategoryId String?
  College          College         @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  CourseCategory   CourseCategory? @relation(fields: [courseCategoryId], references: [id])

  @@index([collegeId])
  @@index([durationInYears])
  @@index([level])
  @@index([name])
  @@index([tuitionFee])
}

model CourseCategory {
  id              String   @id
  name            String   @unique
  description     String
  rules           String
  expectedJobs    String[]
  avgPackage      Float?
  enrollmentStats String?
  opportunities   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  Course          Course[]

  @@index([name])
}

model Cutoff {
  id        String  @id
  collegeId String
  examName  String
  maxRank   Int
  category  String?
  College   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
  @@index([examName])
  @@index([examName, maxRank])
  @@index([maxRank])
}

model Event {
  id          String   @id
  collegeId   String
  title       String
  description String?
  date        DateTime
  type        String
  College     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model Exam {
  id          String    @id
  name        String    @unique
  fullName    String?
  description String?
  date        DateTime?
  type        String?
  level       String?
  imgUrl      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime

  @@index([level])
}

model Facility {
  id              String            @id
  name            String            @unique
  iconUrl         String?
  CollegeFacility CollegeFacility[]
}

model PlacementStat {
  id                  String   @id
  collegeId           String
  year                Int
  highestPackage      Float?
  averagePackage      Float?
  placementPercentage Float?
  topRecruiters       String[]
  College             College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model Question {
  id        String   @id
  text      String
  collegeId String
  createdAt DateTime @default(now())
  authorId  String
  Answer    Answer[]
  User      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  College   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id
  collegeId String
  userId    String
  rating    Float
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  College   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
  @@index([collegeId])
  @@index([userId])
}

model User {
  id                     String                   @id
  username               String                   @unique
  email                  String?                  @unique
  password               String?
  role                   String                   @default("STUDENT")
  avatarUrl              String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  Answer                 Answer[]
  Question               Question[]
  Review                 Review[]
  UserAcademicRecord     UserAcademicRecord[]
  UserCollegePreferences UserCollegePreferences[]
  UserProfile            UserProfile?
}

model UserAcademicRecord {
  id       String  @id
  userId   String
  examName String
  score    Float?
  rank     Int?
  category String?
  User     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserCollegePreferences {
  id        String  @id
  userId    String
  collegeId String
  College   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  User      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id                String   @id
  userId            String   @unique
  fullName          String?
  mobileNumber      String?
  gender            String?
  city              String?
  studyDestination  String?
  currentStatus     String?
  courseInterested  String?
  educationDetails  Json?
  experienceDetails Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/* ------------  from here all model for online editor ---------- */


enum Level {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id                 String     @id @default(uuid())
  name               String
  problem_number     Int        @unique
  github_oid         String     @unique // Link to your GitHub file structure
  problem_definition String     @db.Text
  problem_hints      String[]
  difficulty_level   Level
  
  // Relations
  test_cases         TestCase[]
  code_snippets      CodeSnippet[] // To store starter code for Java/JS
  
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model TestCase {
  id             String   @id @default(uuid())
  input          String   @db.Text // Input to be piped into Docker
  expectedOutput String   @db.Text // Output to compare against
  is_public      Boolean  @default(true) // Public cases show in the UI
  
  problemId      String
  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model CodeSnippet {
  id        String  @id @default(uuid())
  language  String  // "java", "javascript"
  code      String  @db.Text // The boilerplate/starter code
  
  problemId String
  wrapperCode String? @db.Text
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}